{
  "name": "yujian-miniprogram",
  "version": "0.1.0",
  "private": true,
  "description": "育见微信小程序支线",
  "templateInfo": {
    "name": "default",
    "typescript": true
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "typecheck": "tsc --noEmit",
    "style-parity-audit": "node scripts/style-parity-audit.mjs",
    "health-check": "node scripts/health-check.mjs",
    "audit-share": "node scripts/audit-share.mjs",
    "release-check": "npm run typecheck && npm run build:weapp && npm run audit-share"
  },
  "browserslist": ["last 3 versions", "Android >= 4.1", "ios >= 8"],
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "3.6.35",
    "@tarojs/helper": "3.6.35",
    "@tarojs/plugin-framework-react": "3.6.35",
    "@tarojs/plugin-platform-weapp": "3.6.35",
    "@tarojs/react": "3.6.35",
    "@tarojs/runtime": "3.6.35",
    "@tarojs/shared": "3.6.35",
    "@tarojs/taro": "3.6.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
    "@tarojs/cli": "3.6.35",
    "@tarojs/webpack5-runner": "3.6.35",
    "@types/react": "^18.2.0",
    "babel-preset-taro": "3.6.35",
    "typescript": "^5.5.2",
    "webpack": "5.91.0"
  },
  "overrides": {
    "webpack": "5.91.0"
  }
}
