NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_USE_MOCK=true

AI_PROVIDER=fastai
FAST_AI_PROVIDER=deepseek
FAST_AI_BASE_URL=https://api.deepseek.com/v1
FAST_AI_MODEL=deepseek-v4-flash
FAST_AI_API_KEY=
FAST_AI_TEMPERATURE=0.25

ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=
ARK_TEMPERATURE=0.35

# 向量检索（架构-1）：默认阿里百炼 text-embedding-v3（1024 维，批量上限 10 条）。
# 留空则检索自动降级为「取最近」，功能不受影响。embedding 计费独立于 chat。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BATCH_SIZE=10

AUTH_COOKIE_SECURE=false

DATABASE_URL=
PG_POOL_MAX=5

INTERNAL_API_TOKEN=

# 可选：仅当 git fetch 无凭据时，供 npm run sync:gitee 拉取 Gitee（勿提交真实值）
GITEE_PRIVATE_TOKEN=
