# =============================================================================
# ChildOS 环境变量说明
# 复制为 .env.local 后填写；勿提交 .env.local 到 Git
# 生产模板可参考：node scripts/optimize-env.mjs（基于现有 .env.local 整理）
# 部署前自检：node scripts/validate-env.mjs
# =============================================================================

# —— 运行模式 ——
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
# 生产必须为 false，否则数据进进程内存、重启丢失
NEXT_PUBLIC_USE_MOCK=true

# —— 主 LLM（OpenAI 兼容 API）——
# 当前代码只读 FAST_AI_*，不再使用 ARK_* / AI_PROVIDER
FAST_AI_PROVIDER=deepseek
FAST_AI_BASE_URL=https://api.deepseek.com/v1
# 常用：deepseek-chat | deepseek-v4-flash（以账号可用模型为准）
FAST_AI_MODEL=deepseek-v4-flash
FAST_AI_API_KEY=
FAST_AI_TEMPERATURE=0.25
# 可选超时（毫秒）
# FAST_AI_TIMEOUT_MS=45000
# FAST_AI_STREAM_IDLE_MS=25000

# —— 向量检索（生产 /api/readiness ready 必需）——
# 阿里百炼 DashScope，与 chat 计费独立
EMBEDDING_API_KEY=
# 或别名：DASHSCOPE_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BATCH_SIZE=10
RETRIEVAL_TIME_TAU=30
RETRIEVAL_COARSE_K=20

# —— PostgreSQL + pgvector ——
# 本地：docker run -d -e POSTGRES_PASSWORD=childos -e POSTGRES_DB=childos -p 5433:5432 pgvector/pgvector:pg16
DATABASE_URL=
PG_POOL_MAX=8

# —— 鉴权 ——
# 内部脚本/部署验证用；建议独立随机串，勿与 FAST_AI_API_KEY 相同
INTERNAL_API_TOKEN=
# HTTPS 生产站点（如 yujian.yihe.site）设为 true
AUTH_COOKIE_SECURE=false

# —— 后台任务队列（需 DB + NEXT_PUBLIC_USE_MOCK=false）——
JOB_POLLER=
JOB_POOL_MAX=2
JOB_BATCH=2
JOB_POLL_MS=3000
JOB_ZOMBIE_MIN=15

# —— 管理员后台 /admin ——
ADMIN_PHONES=
# 生产默认关闭；本地开发 NODE_ENV=development 时自动开放。Demo 账号永无 admin。
DEMO_LOGIN_ENABLED=false
# 已废弃：DEMO_ADMIN 不再生效
SETTINGS_ENC_KEY=

# —— 微信小程序（POST /api/auth/wechat）——
WECHAT_APPID=
WECHAT_SECRET=

# —— 腾讯云实时语音识别（语音转写）——
# 生产启动：npm run build && npm run asr:start（PM2 指向 server.js）
TENCENT_APPID=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
ASR_PROXY_PORT=3001

# —— 可选：Gitee 同步 ——
GITEE_PRIVATE_TOKEN=

# =============================================================================
# 已废弃（docx/旧配置里可能有，可删除）
# AI_PROVIDER, ARK_API_KEY, ARK_BASE_URL, ARK_MODEL, DB_PASSWORD
# =============================================================================

# =============================================================================
# 生产最小集（yujian.yihe.site）
# NEXT_PUBLIC_USE_MOCK=false
# DATABASE_URL=postgresql://...@127.0.0.1:5432/childos_mvp
# FAST_AI_API_KEY + FAST_AI_MODEL
# EMBEDDING_API_KEY  （缺则 ready=false）
# INTERNAL_API_TOKEN （deploy.sh 的 AUTH_TOKEN 需与此一致）
# AUTH_COOKIE_SECURE=true
# TENCENT_* （语音）
# =============================================================================
