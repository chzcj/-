NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_USE_MOCK=true

# Real AI/backend integration placeholders. Keep these server-side only.
AI_PROVIDER=mock
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=
ARK_TEMPERATURE=0.35

# Use false while testing over http. Change to true after HTTPS is ready.
AUTH_COOKIE_SECURE=false

# Use PostgreSQL in production, for example:
# NEXT_PUBLIC_USE_MOCK=false
# DATABASE_URL=postgresql://childos:password@127.0.0.1:5432/childos_mvp
DATABASE_URL=
PG_POOL_MAX=5
