NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_USE_MOCK=true

AI_PROVIDER=fastai
FAST_AI_PROVIDER=deepseek
FAST_AI_BASE_URL=https://api.deepseek.com/v1
FAST_AI_MODEL=deepseek-v4-flash
FAST_AI_API_KEY=
FAST_AI_TEMPERATURE=0.25

ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=
ARK_TEMPERATURE=0.35

# 向量检索（架构-1）：默认阿里百炼 text-embedding-v3（1024 维，批量上限 10 条）。
# 留空则检索自动降级为「取最近」，功能不受影响。embedding 计费独立于 chat。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BATCH_SIZE=10

# 三层语义检索（EvidenceEpisode+FactAtom）需要 pgvector。
# 本地验证：docker run -d -e POSTGRES_PASSWORD=childos -e POSTGRES_DB=childos -p 5433:5432 pgvector/pgvector:pg16
# 生产 DB 需支持 CREATE EXTENSION vector；不支持则自动降级到应用层 cosine。
# 可选检索参数：
RETRIEVAL_TIME_TAU=30
RETRIEVAL_COARSE_K=20

# 后台任务队列 job_queue（文档 14.3）。需 DB。
# JOB_POLLER：dev 默认关（避免 HMR 多 worker），设 true 在 dev 也启动 poller；生产恒开。
# 注意：DB 未启用时后台写入走 inline 降级（无重试、无节流）。
JOB_POLLER=
JOB_POOL_MAX=2
JOB_BATCH=2
JOB_POLL_MS=3000
JOB_ZOMBIE_MIN=15

AUTH_COOKIE_SECURE=false

DATABASE_URL=
PG_POOL_MAX=5

INTERNAL_API_TOKEN=

# 语音转文字（ASR）：腾讯云「实时语音识别」。配齐这三项后，
# 用自定义服务器启动即可真转写：npm run asr:dev（开发）或 npm run build && npm run asr:start（生产）。
# 留空也不影响打字与其它功能——前端语音按钮会显示「未配置/连接失败」可见降级，不崩。
# 获取：腾讯云控制台 → 语音识别 ASR → 实时语音识别；APPID/SecretId/SecretKey 在「访问管理-API密钥」。
TENCENT_APPID=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
# 可选：旁路 ASR 代理 asr-proxy.js 的端口（默认 3001）。用 server.js 时无需此项。
ASR_PROXY_PORT=3001

# 可选：仅当 git fetch 无凭据时，供 npm run sync:gitee 拉取 Gitee（勿提交真实值）
GITEE_PRIVATE_TOKEN=
