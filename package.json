{
  "name": "childos-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prompts": "node scripts/build-prompts.mjs",
    "predev": "node scripts/build-prompts.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "prebuild": "node scripts/build-prompts.mjs && node scripts/scope-hifi-app-css.mjs && node scripts/scope-hifi-build-css.mjs",
    "build": "NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "next start",
    "asr:dev": "node scripts/build-prompts.mjs && NODE_ENV=development NEXT_IGNORE_INCORRECT_LOCKFILE=1 node server.js",
    "asr:start": "NODE_ENV=production node server.js",
    "pretypecheck": "node scripts/build-prompts.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "check": "npm run validate:env && NEXT_IGNORE_INCORRECT_LOCKFILE=1 npm run build && npm run typecheck",
    "scope:hifi": "node scripts/scope-hifi-app-css.mjs && node scripts/scope-hifi-build-css.mjs",
    "test:build-flow": "node scripts/test-build-flow.mjs",
    "corpus:adapt": "node scripts/adapt-xiaoyin-corpus.mjs",
    "test:xiaoyin-corpus": "node scripts/test-xiaoyin-corpus.mjs",
    "audit:daily-secondme": "node scripts/audit-daily-secondme.mjs",
    "audit:memory": "node scripts/audit-memory-retrieval.mjs",
    "audit:memory-contract": "node scripts/audit-memory-contract.mjs",
    "test:frontend-read-pack": "npx tsx scripts/test-frontend-read-pack.mjs",
    "verify:conditional-profile": "node scripts/verify-conditional-profile-reads.mjs",
    "test:contracts": "npx tsx scripts/test-daily-contract.mjs && npx tsx scripts/test-daily-stream-client.mjs && npx tsx scripts/test-frontend-read-pack.mjs && node scripts/verify-conditional-profile-reads.mjs && node scripts/test-retrieval-packet.mjs && node scripts/audit-memory-contract.mjs && node scripts/audit-deep-modeling-pipeline.mjs",
    "test:account-lifecycle": "node scripts/test-account-lifecycle.mjs",
    "deploy": "bash deploy.sh",
    "sync:gitee": "node .agents/scripts/sync-gitee.mjs",
    "mp:install": "npm install --prefix miniprogram",
    "mp:dev": "npm run dev:weapp --prefix miniprogram",
    "mp:build": "npm run build:weapp --prefix miniprogram"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "lucide-react": "^0.468.0",
    "next": "^14.2.35",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "typescript": "^5.5.2"
  }
}
